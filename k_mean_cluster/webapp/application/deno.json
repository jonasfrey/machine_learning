{
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-write --allow-env --allow-ffi server/server.js",
    "rmdb": "deno run --allow-read --allow-write server/rmdb.js"
  },
  "imports": {
    "@db/sqlite": "jsr:@db/sqlite@^0.12.0"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "singleQuote": true,
    "semiColons": true
  }
}
